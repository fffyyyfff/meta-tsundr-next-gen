apiVersion: v1
kind: Secret
metadata:
  name: meta-tsundr-secrets
  namespace: meta-tsundr
type: Opaque
stringData:
  DATABASE_URL: "postgresql://<user>:<password>@<host>:5432/<db>"
  QDRANT_URL: "http://<qdrant-host>:6333"
  ANTHROPIC_API_KEY: ""
  FIGMA_ACCESS_TOKEN: ""
  LINEAR_API_KEY: ""
  GITHUB_CLIENT_ID: ""
  GITHUB_CLIENT_SECRET: ""
  NEXT_PUBLIC_APP_URL: "http://localhost:3000"
