generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookStatus {
  WISHLIST
  UNREAD
  READING
  FINISHED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  agents          AgentExecution[]
  projects        Project[]
  books           Book[]
  items           Item[]
  gmailConnection GmailConnection?
}

enum ItemCategory {
  BOOK
  ELECTRONICS
  DAILY_GOODS
  FOOD
  CLOTHING
  HOBBY
  OTHER
}

enum ItemStatus {
  WISHLIST
  PURCHASED
  IN_USE
  COMPLETED
  RETURNED
}

model Item {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     ItemCategory
  title        String
  creator      String?
  externalId   String?
  status       ItemStatus   @default(PURCHASED)
  imageUrl     String?
  price        Int?
  purchaseDate DateTime?
  source       String?
  productUrl   String?
  notes        String?      @db.Text
  rating       Int?
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  @@index([userId, category])
  @@index([userId, status])
  @@index([userId, deletedAt])
  @@index([externalId])
}

model Book {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  author     String
  isbn       String?
  status     BookStatus  @default(UNREAD)
  imageUrl   String?
  notes      String?     @db.Text
  rating     Int?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?

  @@index([userId, status])
  @@index([userId, deletedAt])
  @@index([isbn])
}

model Project {
  id               String               @id @default(cuid())
  name             String
  description      String?
  figmaUrl         String?
  linearTeamId     String?
  userId           String
  user             User                 @relation(fields: [userId], references: [id])
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  agents           AgentExecution[]
  designTokens     DesignToken[]
  generatedComponents GeneratedComponent[]
}

model AgentExecution {
  id         String   @id @default(cuid())
  agentType  String
  task       String
  result     String?  @db.Text
  status     String   @default("pending")
  duration   Int?
  tokenUsage Int?
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DesignToken {
  id        String   @id @default(cuid())
  name      String
  value     String
  category  String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
}

model GeneratedComponent {
  id          String   @id @default(cuid())
  name        String
  code        String   @db.Text
  path        String
  figmaNodeId String?
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApiUsage {
  id             String   @id @default(cuid())
  agentType      String
  inputTokens    Int
  outputTokens   Int
  responseTimeMs Int
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([agentType, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  event     String
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  metadata  String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model WebhookConfig {
  id        String   @id @default(cuid())
  userId    String   @unique
  slackUrl  String?
  events    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GmailConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  lastSyncAt   DateTime?
  email        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
